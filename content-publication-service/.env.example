APP_NAME="Content Publication Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database — sesuaikan dengan konfigurasi kelompok
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=db_content_publication
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Storage untuk foto/gambar
FILESYSTEM_DISK=public

# URL microservice lain (untuk komunikasi antar service)
AUTH_SERVICE_URL=http://localhost:8000
NOTIFICATION_SERVICE_URL=http://localhost:8003

# Port service ini
APP_PORT=8001
